    {
      "name": "CREATE NEW USER--SQL injection",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Verify that the API properly handles SQL injection attempts.",
              "pm.test(\"SQL injection processesd  as plain text\", function() {",
              "    pm.expect(pm.response.code).to.be.oneOf([201,202])",
              "});",
              "",
              "// Verify that database error messages are not exposed in the response",
              "",
              "const responseText = pm.response.text();",
              "",
              "const dbErrorPatterns = [",
              "    \"sql syntax\",",
              "    \"sql error\",",
              "    \"mysql\",",
              "    \"postgres\",",
              "    \"database error\",",
              "    \"sqlite\",",
              "    \"ora-\",",
              "    \"syntax error\",",
              "    \"query failed\"",
              "];",
              "",
              "let foundError = false;",
              "",
              "dbErrorPatterns.forEach(function(pattern) {",
              "    if (responseText.toLowerCase().includes(pattern)) {",
              "        foundError = true;",
              "    }",
              "});",
              "",
              "pm.test(\"Response should not contain database error messages\", function () {",
              "    pm.expect(foundError).to.be.false;",
              "});",
              "// Verify that authentication is not bypassed",
              "",
              "const response = pm.response.json();",
              "",
              "pm.test(\"Response should not contain authenticated user data\", function () {",
              "    pm.expect(response).not.to.have.property(\"token\");",
              "    pm.expect(response).not.to.have.property(\"userId\");",
              "});"
            ],
