    {
      "name": "GET  CREAED USER",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verify that the retrieved user matches the created user.",
              "pm.test(\"value of json fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.eql(pm.collectionVariables.get(\"id\"));",
              "    pm.expect(jsonData.name).to.eql(pm.collectionVariables.get(\"username_col\"));",
              "    pm.expect(jsonData.email).to.eql(pm.collectionVariables.get(\"email_col\"));",
              "});",
              "",
              "//Verify the data type of the response body.",
              "const jsonData=pm.response.json();",
              "pm.test(\"test the data type of the response body\", function () {",
              "    pm.expect(jsonData).to.be.an('object');",
              "    pm.expect(jsonData.name).to.be.a(\"String\");",
              "    pm.expect(jsonData.id).to.be.a(\"Number\");",
              "    pm.expect(jsonData.email).to.be.a(\"string\");",
              "});",
              "",
              "//Verify the JSON Schema",
              "var schema={",
              "  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",",
              "  \"title\": \"Generated Schema\",",
              "  \"type\": \"object\",",
              "  \"properties\": {",
              "    \"id\": {",
              "      \"type\": \"integer\"",
              "    },",
              "    \"name\": {",
              "      \"type\": \"string\"",
              "    },",
              "    \"email\": {",
              "      \"type\": \"string\",",
              "      \"format\": \"email\"",
              "    },",
              "    \"gender\": {",
              "      \"type\": \"string\"",
              "    },",
              "    \"status\": {",
              "      \"type\": \"string\"",
              "    }",
              "  },",
              "  \"required\": [",
              "    \"id\",",
              "    \"name\",",
              "    \"email\",",
              "    \"gender\",",
              "    \"status\"",
              "  ]",
              "}",
              "",
              "pm.test(\"Schema is valid\", function () {",
              "    pm.expect(tv4.validate(jsonData,schema)).to.be.true;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
