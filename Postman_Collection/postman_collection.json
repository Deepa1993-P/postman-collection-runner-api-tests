    {
      "name": "CREATE NEW USER--Valid token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Verify that the appropriate status code is returned when a valid Bearer token is included in the request.",
              "pm.test(\"Successful Post Requset\", function() {",
              "    pm.expect(pm.response.code).to.be.oneOf([201,202])",
              "});",
              "",
              "pm.test(\"Status code name has string\", function() {",
              "    pm.response.to.have.status('Created')",
              "});",
              "//Verify cookies when a valid Bearer token is included in the request.",
              "pm.test(\"cookies 'ahoy_visit' is present\", function() {",
              "    pm.expect(pm.cookies.has(\"ahoy_visit\")).to.be.true;",
              "});",
              "//Verify that the request response time is within the acceptable limit.",
              "pm.test(\"response time is less thatn 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "//Verify that the response body contains the correct data.",
              "pm.test(\"value of json fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"active\");",
              "   pm.expect(jsonData.name).to.eql(pm.collectionVariables.get(\"username_col\"));",
              "   pm.expect(jsonData.email).to.eql(pm.collectionVariables.get(\"email_col\"));",
              "});",
              "",
              "// Get response ID from Create API",
              "const response = pm.response.json();",
              "const newId = response.id;",
              "",
              "// Get previously stored IDs",
              "let createdIds = pm.collectionVariables.get(\"createdIds\");",
              "",
              "createdIds = createdIds ? JSON.parse(createdIds) : [];",
              "",
              "// Check duplicate ID",
              "pm.test(\"No duplicate IDs created\", function () {",
              "    pm.expect(createdIds).to.not.include(newId);",
              "});",
              "",
              "//verify no data leakage between Collection Runner iterations",
              "",
              "const currentEmail = response.email;",
              "const currentId = response.id;",
              "",
              "// Get previous iteration values",
              "let previousRecords = pm.collectionVariables.get(\"iterationRecords\");",
              "",
              "previousRecords = previousRecords ",
              "    ? JSON.parse(previousRecords) ",
              "    : [];",
              "",
              "// Validate no data leakage",
              "pm.test(\"No duplicate email used across iterations\", function () {",
              "    let emails = previousRecords.map(record => record.email);",
              "    pm.expect(emails).to.not.include(currentEmail);",
              "});",
              "",
              "//Creating collection variable to store the id of the created user.",
              "var jsonData = JSON.parse(pm.response.text());",
              "pm.collectionVariables.set(\"id\", jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
